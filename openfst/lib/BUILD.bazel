        "@com_google_absl//absl/types:span",
    ],
)

fst_cc_library(
    name = "lib_export_dynamic",
    # Needed for loading definitions from shared objects.
    linkopts = ["-Wl,--export-dynamic"],
    deps = [":lib"],
)

fst_cc_library(
    name = "fst-types",
    srcs = ["fst-types.cc"],
    deps = [
        ":lib_lite",
        ":register",
