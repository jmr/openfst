# This version does not have export-dynamic flag set and should not be used to
# load dynamic-shared object FST extensions. Please see "lib_export_dynamic"
# rule below for binaries that need DSO loading.
# lib_lite does not include type registration for default Fst types.
# Use target "lib" to include default type registration.
fst_cc_library(
    name = "lib_lite",
    srcs = [
        "encode.cc",
        "fst.cc",
        "properties.cc",
        "symbol-table-ops.cc",
    ],
    hdrs = PUBLIC_HEADERS,
    deps = [
        ":file-util",
        ":fst-decl",
        ":interval-set",
        ":register",
        ":symbol-table",
        ":union-find",
        ":util",
        ":weight",
        ":windows_defs",
        "//openfst/compat:compat_memory",
        "@com_google_absl//absl/base",
        "@com_google_absl//absl/base:core_headers",
        "@com_google_absl//absl/base:dynamic_annotations",
        "@com_google_absl//absl/base:nullability",
        "@com_google_absl//absl/container:fixed_array",
        "@com_google_absl//absl/container:flat_hash_map",
        "@com_google_absl//absl/container:flat_hash_set",
        "@com_google_absl//absl/container:node_hash_set",
        "@com_google_absl//absl/flags:flag",
        "@com_google_absl//absl/hash",
        "@com_google_absl//absl/log",
        "@com_google_absl//absl/log:check",
        "@com_google_absl//absl/memory",
        "@com_google_absl//absl/strings",
        "@com_google_absl//absl/types:span",
    ],
)

fst_cc_library(
    name = "lib",
    hdrs = PUBLIC_HEADERS,
    deps = [
        ":file-util",
        ":fst-decl",
        ":fst-types",
        ":interval-set",
        ":lib_lite",
        ":register",
        ":symbol-table",
        ":union-find",
        ":util",
        ":weight",
        ":windows_defs",
        "//openfst/compat:compat_memory",
        "@com_google_absl//absl/base",
        "@com_google_absl//absl/base:core_headers",
        "@com_google_absl//absl/base:dynamic_annotations",
        "@com_google_absl//absl/base:nullability",
        "@com_google_absl//absl/container:fixed_array",
        "@com_google_absl//absl/container:flat_hash_map",
        "@com_google_absl//absl/container:flat_hash_set",
        "@com_google_absl//absl/container:node_hash_set",
        "@com_google_absl//absl/flags:flag",
        "@com_google_absl//absl/hash",
        "@com_google_absl//absl/log",
        "@com_google_absl//absl/log:check",
