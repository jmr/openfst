        "symbol-table.cc",
    ],
    hdrs = [
        "compat-util.h",
        "symbol-table.h",
    ],
    deps = [
        ":file-stream-status",
        ":file-util",
        ":util",
        ":windows_defs",
        "//openfst/compat",
